# =============================================================================
# AI Trading Co-Pilot — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# All values below are optional — the app runs fully with mock data by default.

# --- Server ---
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Market Data Providers (optional — mock data used if absent) ---
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=

# --- AI / LLM (optional — mock agent responses used if absent) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Vector Database (optional — in-memory FAISS used if absent) ---
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=trading-copilot
